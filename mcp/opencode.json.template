{
  "$schema": "https://opencode.ai/config.json",
  "description": "OpenCode configuration - default template (local-first)",
  "plugin": [
    "opencode-pty",
    "opencode-agent-skills",
    "superlocalmemory",
    "superpowers"
  ],
  "mcpServers": {
    "searxng": {
      "type": "stdio",
      "command": "node",
      "args": ["/opt/searxng-mcp/build/index.js"],
      "env": {
        "SEARXNG_URL": "http://100.110.14.68:8080/"
      }
    }
  },
  "provider": {
    "openrouter": {
      "options": {
        "websearch_cited": {
          "model": "x-ai/grok-4.1-fast"
        }
      }
    }
  },
  "NOTE": {
    "memory": "Using superlocalmemory (Mode A - 100% local). For cloud-based memory, use opencode-supermemory instead.",
    "installation": "npm install -g superlocalmemory && slm setup"
  }
}